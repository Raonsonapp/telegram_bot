# ── Required ─────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# GitHub classic Personal Access Token with the "repo" scope.
# Used to create per-user repos, push code, trigger GitHub Actions,
# and download the built APK artifacts.
GITHUB_APP_BUILDER_TOKEN=

# OpenRouter API key (free tier works) for AI design + code generation.
OPENROUTER_API_KEY=

# ── Optional ─────────────────────────────────────────────
# Override the default primary LLM (a fallback list is used regardless).
OPENROUTER_MODEL=

# Telegram ID that receives "Contact Admin" messages and price orders.
# Send /myid to the bot to find yours.
ADMIN_CHAT_ID=

# Comma-separated @channels the user must join before using the bot.
# Example: REQUIRED_CHANNELS=@my_channel,@sponsor_channel
REQUIRED_CHANNELS=

# Master switch for the sponsor / forced-subscription gate.
# Default is OFF (no sponsor shown). Set to "true" to enforce
# REQUIRED_CHANNELS. The channel list is preserved either way, so you
# can toggle the gate without losing it.
SPONSOR_ENABLED=false

# Default interface language: fa (default) | ru | en
DEFAULT_LANGUAGE=fa

# SQLite database path (ephemeral on Render; durable data lives on GitHub).
DB_PATH=./data/appbuilder.db

# HTTP port (Render sets this automatically).
PORT=10000

# Set to "true" for verbose Telegram + debug logging.
DEBUG=false
